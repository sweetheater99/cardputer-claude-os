# Copy to .env and fill in:  cp env.example .env
# Both values come from the Claude Console (Manage > MCP tunnels) after
# you create a tunnel. .env is gitignored — never commit it.

# The domain assigned to your tunnel, e.g. abcd1234.tunnel.anthropic.com
# (NOT secret — it's also baked into the server cert SAN by gen-certs.sh).
TUNNEL_DOMAIN=

# The tunnel connection token (a long "eyJ..." secret). Rotate it in the
# Console if it leaks. Treat as a high-value secret.
TUNNEL_TOKEN=
